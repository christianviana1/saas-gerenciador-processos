# ─────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────
# MySQL 8.0+ connection string
DATABASE_URL="mysql://user:password@localhost:3306/sistema_juridico"

# ─────────────────────────────────────────────────────────────────
# REDIS (BullMQ + Cache)
# ─────────────────────────────────────────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""
# Optional: Redis DB index (default 0)
REDIS_DB="0"
# Optional: Redis TLS (set to "true" for production)
REDIS_TLS="false"

# ─────────────────────────────────────────────────────────────────
# AUTH.JS v5 (NextAuth)
# ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-secure-random-256-bit-base64-encoded-secret"
NEXTAUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────────
# VAPID — Web Push Notifications (PWA)
# ─────────────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="replace-with-your-vapid-public-key"
VAPID_PRIVATE_KEY="replace-with-your-vapid-private-key"
VAPID_SUBJECT="mailto:admin@yourdomain.com"

# ─────────────────────────────────────────────────────────────────
# AES-256-GCM Encryption (sensitive fields at rest)
# ─────────────────────────────────────────────────────────────────
# 32-byte hex key — generate with: openssl rand -hex 32
AES_ENCRYPTION_KEY="replace-with-64-char-hex-string-representing-32-bytes"

# ─────────────────────────────────────────────────────────────────
# SMTP (Email Service)
# ─────────────────────────────────────────────────────────────────
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="noreply@yourdomain.com"
SMTP_PASSWORD="replace-with-smtp-password"
SMTP_FROM_NAME="Sistema Jurídico"
SMTP_FROM_EMAIL="noreply@yourdomain.com"

# ─────────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────────
NODE_ENV="development"
APP_URL="http://localhost:3000"
# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL="info"

# ─────────────────────────────────────────────────────────────────
# DATAJUD (CNJ API)
# ─────────────────────────────────────────────────────────────────
DATAJUD_API_URL="https://api-publica.datajud.cnj.jus.br"
DATAJUD_API_KEY=""
# Sync interval in milliseconds (default: 86400000 = 24h)
DATAJUD_SYNC_INTERVAL_MS="86400000"

# ─────────────────────────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────────────────────────
# Max login attempts before block (Req 5.5)
RATE_LIMIT_LOGIN_MAX="5"
# Block duration in seconds (default: 900 = 15 min)
RATE_LIMIT_LOGIN_BLOCK_DURATION="900"
# General API rate limit (requests per minute per IP)
RATE_LIMIT_API_RPM="100"

# ─────────────────────────────────────────────────────────────────
# PLAYWRIGHT (E2E Tests)
# ─────────────────────────────────────────────────────────────────
PLAYWRIGHT_BASE_URL="http://localhost:3000"
