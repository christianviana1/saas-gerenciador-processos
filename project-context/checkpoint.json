  "keyDecisions": {
    "database": "MySQL 8.0 + Prisma ORM 5",
    "auth": "Auth.js v5 JWT HS256 8h + TOTP MFA",
    "multitenancy": "Row-level via tenant_id (repository layer enforcement)",
    "queues": "BullMQ 5 + Redis 7 (4 queues: datajud-sync, notifications, audit, email)",
    "passwordHashing": "Argon2id (64MB, 3 iter, 4 parallel, 16-byte salt)",
    "encryption": "AES-256-GCM for sensitive fields at rest",
    "pbt": "fast-check with Vitest (Properties 1-9)",
    "csp": "Per-request nonce via Edge Middleware, no unsafe-inline",
    "ssrf": "Shared ssrfValidator utility blocking RFC 1918 + link-local ranges",
    "cache": "Redis cache layer for tenant config (5min TTL)",
    "circuitBreaker": "In-memory circuit breaker in DataJudClient (5 failures → 30s wait)",
    "auditImmutability": "Append-only repository + SHA-256 payload_hash per record"
  },
